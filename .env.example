# Copy to .env and fill values (do NOT commit .env)

# App
APP_ENV=local
APP_DEBUG=0

# PHP sessions
SESSION_SAMESITE=Lax

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gtorg_xeyal
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Flask (only if you use app.py / backend/app.py)
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin bootstrap (LOCAL ONLY; do not enable in production)
ALLOW_ADMIN_BOOTSTRAP=0
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ostwindgroup.com
ADMIN_PASSWORD=
